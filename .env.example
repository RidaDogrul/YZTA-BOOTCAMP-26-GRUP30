GOOGLE_API_KEY=buraya_kendi_anahtarini_yaz

# PostgreSQL — docker-compose.yml ile aynı kimlik bilgileri
DATABASE_URL=postgresql+psycopg2://postgres:3456@localhost:5434/pizza_runner

# AWS S3 (opsiyonel — konnektör testi için)
AWS_ACCESS_KEY_ID=buraya_access_key_yaz
AWS_SECRET_ACCESS_KEY=buraya_secret_key_yaz
AWS_S3_BUCKET=ornek-bucket-adi
AWS_REGION=eu-central-1
AWS_S3_PREFIX=
# AWS_ENDPOINT_URL=  # MinIO / LocalStack gibi S3 uyumlu servisler için
