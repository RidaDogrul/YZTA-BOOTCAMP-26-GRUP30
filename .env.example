GOOGLE_API_KEY=buraya_kendi_anahtarini_yaz

# Gemini model seçimi (varsayılan: gemini-1.5-flash, ücretsiz 1500 istek/gün)
# Daha güçlü model istersen: gemini-2.5-flash (ücretsiz 20 istek/gün)
GEMINI_MODEL=gemini-1.5-flash

# PostgreSQL — docker-compose.yml ile aynı kimlik bilgileri
DATABASE_URL=postgresql+psycopg2:/username:password@localhost:port/database_adı

# MySQL (opsiyonel — konnektör testi için)
MYSQL_URL=mysql+pymysql://root:password@localhost:3306/mydb

# AWS S3 (opsiyonel — konnektör testi için)
AWS_ACCESS_KEY_ID=buraya_access_key_yaz
AWS_SECRET_ACCESS_KEY=buraya_secret_key_yaz
AWS_S3_BUCKET=ornek-bucket-adi
AWS_REGION=eu-central-1
AWS_S3_PREFIX=
# AWS_ENDPOINT_URL=  # MinIO / LocalStack gibi S3 uyumlu servisler için

# MongoDB (opsiyonel — konnektör testi için)
MONGODB_URI=mongodb://localhost:27017/mydb
# Alternatif: ayrı parametreler
# MONGODB_HOST=localhost
# MONGODB_PORT=27017
# MONGODB_DATABASE=mydb
# MONGODB_USER=
# MONGODB_PASSWORD=
# MONGODB_AUTH_SOURCE=admin

# Snowflake (opsiyonel — konnektör testi için)
SNOWFLAKE_URL=snowflake://myuser:mypassword@xy12345.eu-central-1/MY_DB/PUBLIC?warehouse=COMPUTE_WH&role=SYSADMIN
# Alternatif: ayrı parametreler
# SNOWFLAKE_ACCOUNT=xy12345.eu-central-1
# SNOWFLAKE_USER=myuser
# SNOWFLAKE_PASSWORD=mypassword
# SNOWFLAKE_DATABASE=MY_DB
# SNOWFLAKE_SCHEMA=PUBLIC
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_ROLE=SYSADMIN
JWT_SECRET_KEY=buraya_uzun_rastgele_bir_secret_yazin
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
